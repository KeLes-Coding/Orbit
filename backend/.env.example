ORBIT_ENV=local
ORBIT_API_PREFIX=/api/v1
ORBIT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/orbit
ORBIT_AUTH_SECRET_KEY=change-me-in-local-env-at-least-32-bytes
ORBIT_ENCRYPTION_SECRET_KEY=change-me-for-api-key-encryption
ORBIT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
ORBIT_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ORBIT_TITLE_PROVIDER=deepseek
ORBIT_TITLE_MODEL=deepseek-chat
ORBIT_TITLE_BASE_URL=https://api.deepseek.com
ORBIT_TITLE_API_KEY=
ORBIT_TITLE_TIMEOUT_SECONDS=10
ORBIT_TITLE_MAX_CHARS=48
ORBIT_LLM_DEBUG_LOGGING=false
ORBIT_LLM_DEBUG_MAX_CHARS=4000
ORBIT_LLM_DEBUG_LOG_PATH=logs/llm-debug.log
